            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "d0d85825-428b-4e9a-8b9f-b32b9d6ada3d",
      "name": "HTTP — Submit to WhisperX",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        480,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// whisperx_api risponde: { job_id, status, customer, project, output_format }\nconst job_id = $json.job_id;\nif (!job_id) throw new Error('whisperx_api non ha restituito job_id: ' + JSON.stringify($json));\n\nconsole.log(`[MinutesAI] Job creato: ${job_id} — ${$json.customer}/${$json.project}`);\n\nreturn [{ json: { job_id, status: $json.status, customer: $json.customer, project: $json.project } }];"
      },
      "id": "081d3390-0dcc-45db-b369-2b7b2a87e79c",
