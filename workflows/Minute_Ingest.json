    {
      "parameters": {
        "jsCode": "// Estrae i campi dal multipart e li logga\nconst body  = $json.body ?? $json;\nconst query = $json.query ?? {};\n\nconst customer      = (body.customer      ?? query.customer      ?? '').trim();\nconst project       = (body.project       ?? query.project       ?? '').trim();\nconst language      = (body.language      ?? query.language      ?? 'it').trim();\nconst max_speakers  = (body.max_speakers  ?? query.max_speakers  ?? '8').toString();\nconst diarize       = (body.diarize       ?? query.diarize       ?? 'true').toString();\nconst output_format = (body.output_format ?? query.output_format ?? 'both').trim();\nconst participants  = (body.participants  ?? query.participants  ?? '').trim();\n\nif (!customer) throw new Error('Campo obbligatorio mancante: customer');\nif (!project)  throw new Error('Campo obbligatorio mancante: project');\n\n// Trova la chiave binaria del file audio\nconst binKeys = Object.keys($binary ?? {});\nif (!binKeys.length) throw new Error('Nessun file audio trovato nel payload');\nconst binKey = binKeys[0];\n\nconsole.log(`[MinutesAI] Ingest — ${customer}/${project} — file: ${$binary[binKey].fileName}`);\n\nreturn [{\n  json: {\n    customer, project, language,\n    max_speakers, diarize, output_format, participants,\n    binKey,\n    receivedAt: new Date().toISOString()\n  },\n  binary: { [binKey]: $binary[binKey] }\n}];"
      },
      "id": "b21b5b0b-5dc5-4ead-a45f-f5d767ef2244",
      "name": "Code — Parse & Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://whisperx_api:8000/jobs",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "parameterType": "formBinaryData",
              "name": "file",
              "inputDataFieldName": "={{ $json.binKey }}"
            },
            {
